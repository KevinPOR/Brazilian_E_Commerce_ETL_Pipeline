   "outputs": [],
   "source": [
    "SELECT o.order_id, c.customer_state, SUM(oi.total_item_value) AS revenue\n",
    "FROM gold.fact_orders o\n",
    "JOIN gold.fact_order_items oi USING (order_id)\n",
    "JOIN gold.dim_customers c USING (customer_id)\n",
    "GROUP BY o.order_id, c.customer_state;"
   ]
